# .env.example — local development configuration (spec 003-local-infra).
#
# Copy to `.env` (git-ignored) and fill REAL values. Every value below set to `CHANGE_ME`
# is a placeholder: services and the Postgres init REFUSE TO START until you replace it
# (SEC-6 / US2). Ports and NODE_ENV are real defaults, not secrets. NEVER commit `.env`.

# --- Runtime ---
NODE_ENV=development

# --- Postgres (one engine; a DB + isolated role per data-owning service) ---
# Superuser (used only by the container + init script to create per-service roles/DBs).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
# Per-service role passwords (init script creates auth_user/users_user/… with these).
AUTH_DB_PASSWORD=CHANGE_ME
USERS_DB_PASSWORD=CHANGE_ME
CHATS_DB_PASSWORD=CHANGE_ME
BRANDS_DB_PASSWORD=CHANGE_ME

# Per-service DATABASE_URL — compose builds these per container from the passwords above.
# Shown here for reference / running a single service outside compose (fill the password):
#   auth  : postgresql://auth_user:<AUTH_DB_PASSWORD>@localhost:5432/auth_db
#   users : postgresql://users_user:<USERS_DB_PASSWORD>@localhost:5432/users_db
#   chats : postgresql://chats_user:<CHATS_DB_PASSWORD>@localhost:5432/chats_db
#   brands: postgresql://brands_user:<BRANDS_DB_PASSWORD>@localhost:5432/brands_db

# --- Redis (shared cache/queue; used by worker via BullMQ and by the gateway) ---
REDIS_URL=redis://localhost:6379

# --- Gateway (single host-exposed ingress: REST + WebSocket) ---
GATEWAY_PORT=3000
# gRPC dial targets (compose sets these to service DNS names; localhost for bare-metal run).
AUTH_GRPC_TARGET=localhost:50051
USERS_GRPC_TARGET=localhost:50052
CHATS_GRPC_TARGET=localhost:50053
BRANDS_GRPC_TARGET=localhost:50054
WORKER_GRPC_TARGET=localhost:50055

# --- Per-backend-service gRPC bind address ---
# Each backend service reads GRPC_URL as its own bind address. Compose sets this per
# container (e.g. auth => 0.0.0.0:50051). For a single bare-metal service run, export the
# matching one, e.g.:  GRPC_URL=0.0.0.0:50051
GRPC_URL=0.0.0.0:50051

# --- Web (Next.js dev server; runs via `npm run dev:web`, not containerised until Phase 8) ---
WEB_PORT=3001
