# .env.example — Phase 0 (documents required keys; NO real values here)
#
# Real secrets live in a git-ignored `.env` (see .gitignore). Copy this file to `.env`
# and fill in local values. Full secret-refusal enforcement is Phase 1; Phase 0 only
# establishes the fail-fast-on-missing-required-config convention.

# --- Gateway ---
# Port the API Gateway listens on (defaults to 3000 if unset).
GATEWAY_PORT=3000

# --- Web ---
# Port the Next.js dev server listens on (kept distinct from the gateway).
WEB_PORT=3001

# --- Runtime ---
NODE_ENV=development
